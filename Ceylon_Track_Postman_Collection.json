{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-1234-567890abcdef",
		"name": "Ceylon Track API",
		"description": "API endpoints for the Ceylon Track Railway System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "1. Login (Admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.token) {",
									"    pm.environment.set(\"jwt_token\", jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"email\": \"admin@ceylontrack.lk\",\r\n    \"password\": \"password123\"\r\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					}
				},
				{
					"name": "2. Get My Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/me",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"me"
							]
						}
					}
				}
			]
		},
		{
			"name": "Public API",
			"item": [
				{
					"name": "3. Search Schedules",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/schedules/search?from=FOT&to=GAL&date=2024-05-15",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"schedules",
								"search"
							],
							"query": [
								{
									"key": "from",
									"value": "FOT",
									"description": "Origin Station Code"
								},
								{
									"key": "to",
									"value": "GAL",
									"description": "Destination Station Code"
								},
								{
									"key": "date",
									"value": "2024-05-15",
									"description": "Date (YYYY-MM-DD)"
								}
							]
						}
					}
				},
				{
					"name": "4. Get All Stations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/stations",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"stations"
							]
						}
					}
				}
			]
		},
		{
			"name": "Admin/Staff (Requires Auth)",
			"item": [
				{
					"name": "5. Get System Stats",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/admin/stats",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"admin",
								"stats"
							]
						}
					}
				},
				{
					"name": "6. Update Train Status (Delay)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"delay_minutes\": 20,\r\n    \"status\": \"Delayed\",\r\n    \"notes\": \"Testing delay from Postman\"\r\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/staff/trains/1/status",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"staff",
								"trains",
								"1",
								"status"
							]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000",
			"type": "string"
		}
	]
}
